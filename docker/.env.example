# ===========================================
# AMBIENTE: local | prod
# ===========================================
ENV=local

# ===========================================
# DOMÍNIO
# Local: localhost | Prod: seudominio.com.br
# ===========================================
DOMAIN=localhost

# ===========================================
# MYSQL
# ===========================================
MYSQL_ROOT_PASSWORD=ALTERE_SENHA_segura_aqui
MYSQL_DATABASE=sistema_academico

# ===========================================
# CONNECTION STRING (.NET)
# ===========================================
ConnectionStrings__DefaultConnection=Server=mysql;Database=sistema_academico;User=root;Password=ALTERE_SENHA_segura_aqui;

# ===========================================
# JWT
# ===========================================
JwtSettings__SecretKey=GERAR_CHAVE_ALEATORIA_DE_32_CARACTERES_AQUI
JwtSettings__Issuer=sgc-api
JwtSettings__Audience=sgc_client

# ===========================================
# SMTP (SendGrid)
# ===========================================
SmtpSettings__SendGridApiKey=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SmtpSettings__FromEmail=seu-email@seudominio.com.br
SmtpSettings__FromName="Sistema de Gestao de Cursos"

# ===========================================
# URLs (ajustadas automaticamente pelo sgc.sh)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost/api/v1
FrontendUrl=http://localhost
